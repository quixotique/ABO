#!/usr/bin/env python3
# vim: sts=4 sw=4 expandtab

r'''Usage:
    rename-exif [-tv] [--test] [--verbose] [--link] [--move-to=DIR] [PATH...]
    rename-exif -h | --help

Options:
    -l --link           Create hard links instead of renaming
    -m --move-to=DIR    Move renamed files to (create links in) in DIR [default .]
    -h --help           Show this message
    -t --test           Calculate but but do not perform; useful with --verbose
    -v --verbose        Print renames before performing
'''

import sys
import os
import os.path
import time
import re
import filecmp
import exifread

sys.path.append(os.path.join(os.path.dirname(os.path.abspath(sys.argv[0])), '..', 'lib', 'docopt'))
import docopt

def main():
    global myname
    myname = os.path.basename(sys.argv[0])
    opts = docopt.docopt(__doc__, sys.argv[1:], version=2.0)
    move_to = os.path.normpath(opts['--move-to'] or '.')
    interpolate(move_to, (0, 0, 0, 0, 0, 0)) # fail early on bad substitution
    # Figure out destination pathnames from all named files.
    paths = [(imagetime(path), os.path.normpath(path)) for path in opts['PATH']]
    paths = [p for p in paths if p[0] is not None]
    stems = {}
    for time, path in paths:
        stem = interpolate('{yyyy}-{mm}-{dd}', time)
        year, month, day, hour, minute, second = time
        stem = "%04u-%02u-%02u" % (year, month, day)
        if stem not in stems:
            stems[stem] = []
        stems[stem].append((time, path))
    map = {}
    for stem, paths in stems.items():
        paths.sort()
        w = len(str(len(paths) - 1))
        n = 0
        for time, path in paths:
            year, month, day, hour, minute, second = time
            i = path.rfind('.')
            root, suffix = path, ''
            if i != -1 and i < len(path) - 1:
                root, suffix = path[:i], path[i:]
            if suffix.lower() in ('.jpg', '.jpeg', '.pjpg', '.pjpeg'):
                suffix = '.jpg'
            if path not in map:
                n += 1
                dst_dir = interpolate(move_to, time)
                dst = os.path.normpath(('%s/%s-%0' + str(w) + 'u%s') % (dst_dir, stem, n, suffix))
                name = os.path.basename(path)
                if dst != name:
                    map[path] = dst
    paths = [(os.path.basename(path), path) for path in map.keys()]
    paths.sort()
    paths = [x[1] for x in paths]
    would_overwrite = 0
    for path in paths:
        dst = map[path]
        if os.access(dst, os.F_OK) and not filecmp.cmp(dst, path):
            print("already exists: %s" % dst, file=sys.stderr)
            would_overwrite += 1
    if would_overwrite != 0:
        fail("would overwrite %u file%s" % (would_overwrite, '' if would_overwrite == 1 else 's'))
    else:
        verbose_mkdirs = set()
        for path in paths:
            dst = map[path]
            dst_dir = os.path.dirname(dst)
            if not os.path.exists(dst_dir):
                if opts['--verbose'] and not dst_dir in verbose_mkdirs:
                    print("mkdirs %s" % (dst_dir,))
                if not opts['--test']:
                    os.makedirs(dst_dir, exist_ok=True)
                else:
                    verbose_mkdirs.add(dst_dir)
            if not (os.path.exists(dst) and filecmp.cmp(path, dst)):
                if opts['--link']:
                    if opts['--verbose']:
                        print("link %s -> %s" % (path, dst))
                    if not opts['--test']:
                        os.link(path, dst)
                else:
                    if opts['--verbose']:
                        print("move %s -> %s" % (path, dst))
                    if not opts['--test']:
                        os.rename(path, dst)

def imagetime(path):
    tags = exifread.process_file(open(path, 'rb'))
    for tag in ('EXIF DateTimeOriginal',
                'EXIF DateTimeDigitized',
                'Image DateTime',):
        if tag in tags:
            value = str(tags[tag])
            value = re.sub(r': (\d)', r':0\1', value)
            try:
                t = time.strptime(value, '%Y:%m:%d %H:%M:%S')
            except ValueError:
                continue
            return t.tm_year, t.tm_mon, t.tm_mday, t.tm_hour, t.tm_min, t.tm_sec
    return None

def interpolate(template, time):
    year, month, day, hour, minute, second = time
    def replace(m):
        if m.group(1) == 'yyyy': return '%04u' % year
        elif m.group(1) == 'mm': return '%02u' % month
        elif m.group(1) == 'dd': return '%02u' % day
        else: fail("invalid substitution: " + m.group(0))
    return re.sub(r'{([^}]*)}', replace, template)

def fail(msg):
    global myname
    print('%s: %s' % (myname, msg), file=sys.stderr)
    sys.exit(1)

if __name__ == '__main__':
    main()

#!/bin/bash
#
# Perform incremental rsync backup copy of the given labelled directory trees
# on the given hosts (default local).

set -e -u
shopt -s extglob nullglob lastpipe

usage() {
    echo "Usage: Push: ${0##*/} [-n] [-q] [RSYNC-OPTS] [--] [[USER@]HOST:]DESTDIR              LABEL[=SOURCEDIR] ..."
    echo "       Pull: ${0##*/} [-n] [-q] [RSYNC-OPTS] [--]               DESTDIR [[USER@]HOST:LABEL[=SOURCEDIR] ..."
}

main() {
    OPT_ECHO=true
    OPT_TEST=false
    OPT_DRY_RUN=false
    OPTS_RSYNC=()
    while [[ $# -ne 0 ]]; do
        case $1 in
        -h|-\?|--help) usage; exit 0;;
        -t) OPT_TEST=true;;
        -n) OPT_DRY_RUN=true;;
        -q) OPT_ECHO=false;;
        -*) OPTS_RSYNC+=("$1");;
        --) shift; break;;
        *) break;;
        esac
        shift
    done

    LOCAL_HOST_FQ=$(/bin/hostname --fqdn)
    [[ $LOCAL_HOST_FQ ]] || fatal "cannot determine default hostname"

    [[ $# -ge 2 ]] || fatal_usage "missing argument(s)"
    parse_rsync_endpoint DEST "$1" # sets DESTUSER DESTHOSTFQ DESTHOST DESTDIR
    [[ -z $DESTHOST && ! -d $DESTDIR ]] && fatal "missing destination directory: $DESTDIR"
    shift

    DATEREXP='[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]'
    DATE=`/bin/date '+%Y-%m-%d'` || exit 2
    ERR="/tmp/${0##*/}-$$.err"

    local PASSWORD=
    if [[ $DESTHOSTFQ != $LOCAL_HOST_FQ ]]; then
        read -s -p "Password for $DESTUSER@$DESTHOST:" PASSWORD
        echo >&2
    fi

    local -a SOURCES=()
    local rsync_output=
    local src
    for src; do
        local SRCUSER
        local SRCHOSTFQ
        local SRCHOST
        local SRCDIR
        parse_rsync_endpoint SRC "$src" # sets SRCUSER SRCHOSTFQ SRCHOST SRCDIR

        if [[ $DESTHOSTFQ != "$LOCAL_HOST_FQ" && $SRCHOSTFQ != "$LOCAL_HOST_FQ" ]]; then
            fatal_usage "cannot push to remote destination from remote source: $src"
        fi

        local SRCLABEL=$SRCDIR
        local SRCPATH

        case "$SRCDIR" in
        ?*=*)   SRCPATH=${SRCDIR#*=}
                SRCPATH=${SRCPATH%%+(/)}
                SRCLABEL=${SRCDIR%%=*}
                ;;
        boot)   SRCPATH=/boot;;
        etc)    SRCPATH=/etc;;
        root)   SRCPATH=/;;
        home)   SRCPATH=/home;;
        bulk)   SRCPATH=/bulk;;
        music)  SRCPATH=/bulk/media/Music;;
        photos) SRCPATH=/bulk/media/Photos;;
        *)      fatal "unsupported label: $SRCDIR";;
        esac

        [[ $SRCHOSTFQ = "$LOCAL_HOST_FQ" && ! -d $SRCPATH ]] && fatal "missing source directory: $SRCPATH"

        local LINK_DEST=
        if [[ $DESTHOSTFQ = "$LOCAL_HOST_FQ" ]]; then
            if pushd "$DESTDIR" >/dev/null 2>/dev/null; then
                LINK_DEST=$(ls -r | sed -n -e "/-$DATE-/d;/^$SRCHOST-$DATEREXP-$SRCLABEL\$/{p;q}")
                popd >/dev/null
            fi
        else
            if [[ -z $rsync_output ]]; then
                rsync_output=$(runalways rsync --password-file - "$DESTUSER@$DESTHOSTFQ::$DESTDIR/" <<<"$PASSWORD") || fatal "rsync failed"
                [[ -z $rsync_output ]] && rsync_output='empty'
            fi
            LINK_DEST=$(sed -n -e "/-$DATE-/d;s/^.* \($SRCHOST-$DATEREXP-$SRCLABEL\)\$/\1/p" <<<"$rsync_output" |
                         sort -r |
                         head -n 1)
        fi

        SOURCES+=("$SRCUSER" "$SRCHOST" "$SRCHOSTFQ" "$SRCLABEL" "$LINK_DEST" "$SRCPATH")
    done

    set -- "${SOURCES[@]}"
    while [[ $# -ne 0 ]]; do
        [[ $# -ge 6 ]] || fatal "Bug: SOURCES only has $# elements left"
        local SRCUSER=$1
        local SRCHOST=$2
        local SRCHOSTFQ=$3
        local SRCLABEL=$4
        local LINK_DEST=$5
        local SRCPATH=$6
        shift 6
        #echo "SRCUSER=$SRCUSER SRCHOST=$SRCHOST SRCHOSTFQ=$SRCHOSTFQ SRCLABEL=$SRCLABEL LINK_DEST=$LINK_DEST SRCPATH=$SRCPATH"

        local src
        local dst
        local -a opts

        opts=()
        if $OPT_DRY_RUN; then
            opts+=("--dry-run")
        fi

        src=$SRCPATH
        if [[ $SRCHOSTFQ != $LOCAL_HOST_FQ ]]; then
            src=$SRCUSER@$SRCHOSTFQ::$src
        fi

        dst=$DESTDIR/$SRCHOST-$DATE-$SRCLABEL
        if [[ $DESTHOSTFQ != $LOCAL_HOST_FQ ]]; then
            dst=$DESTUSER@$DESTHOSTFQ::$dst
            opts+=("--password-file" "-")
        fi

        if [[ $LINK_DEST ]]; then
            opts+=("--link-dest=../$LINK_DEST/")
        fi

        if ! run rsync --verbose --human-readable \
                --one-file-system --archive --hard-links --inplace --delete \
                --exclude '/lost+found' --delete-excluded \
                --filter="dir-merge,- .rsync-backup-exclude" \
                "${opts[@]}" "${OPTS_RSYNC[@]}" "$src/" "$dst/" \
                2>"$ERR" <<<"$PASSWORD"
        then
            rsync_stat=$?
            echo "exit status $rsync_stat"
            return $rsync_stat
        fi

        cat "$ERR" >&2
        echo
    done
}

parse_rsync_endpoint() {
    local -n __user=${1}USER
    local -n __hostfq=${1}HOSTFQ
    local -n __host=${1}HOST
    local -n __dir=${1}DIR
    case $2 in
    ?*:*)
        __dir=${2#*:}
        __user=$LOGNAME
        __host=${2%%:*}
        case $__host in
        *@*) __user=${__host%%@*}; __host=${__host#*@};;
        esac
        __hostfq=$(fqdn "$__host") || fatal "cannot resolve host: $__host"
        ;;
    *)
        __user=$LOGNAME
        __hostfq=$LOCAL_HOST_FQ
        __host=${__hostfq%%.*}
        __dir=$2
        ;;
    esac
}

fqdn()
{
    if result=$(/bin/ping -c 1 -w 1 "$1"); then
        case $result in
        "PING "*" ("[0-9]*)
            result=${result#PING }
            result=${result%%[ (]*}
            echo "$result"
            return 0
            ;;
        esac
    fi
    return 1
}

exec 101>&1 102>&2

fatal() {
    echo "${0##*/}: $1" >&102
    shift
    for arg; do echo "$arg" >&102; done
    exit 1
}

fatal_usage() {
    fatal "$1" "See \`${0##*/} --help' for more information."
}

runalways() {
    $OPT_ECHO && log "$@"
    "$@"
}

run() {
    $OPT_ECHO && log "$@"
    if ! $OPT_TEST; then
        "$@"
    fi
}

log() {
    echo -n + >&101
    printf ' %q' "$@" >&101
    echo >&101
}

main "$@"
